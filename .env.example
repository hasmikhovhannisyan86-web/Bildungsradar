# BildungsRadar - Umgebungsvariablen
# Kopiere diese Datei als .env und trage deine API-Keys ein:
# cp .env.example .env

# Demo-Modus (true = Beispieldaten, false = echte API-Aufrufe)
DEMO_MODE=true

# OpenAI API Key (von https://platform.openai.com/api-keys)
OPENAI_API_KEY=

# Google Maps API Key (von https://console.cloud.google.com)
GOOGLE_MAPS_API_KEY=

# OpenAI Einstellungen
OPENAI_MODEL=gpt-3.5-turbo
OPENAI_TEMPERATURE=0.3
